PORT=3000
CORP_ID=wwxxxxxxxxxxxxxxxx
AGENT_ID=1000002
CORP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WECOM_TOKEN=your_callback_token
ENCODING_AES_KEY=your_43_chars_encoding_aes_key

# 客户群群发（add_msg_template）：发送成员 userid、目标群 chat_id（可逗号分隔多个）
BROADCAST_SENDER=zhangsan
BROADCAST_CHAT_IDS=wrxxxxxxxxxxxxxxxx
BROADCAST_TEXT=你好，这是一条客户群群发测试

# Wechaty（个人微信/非官方接入，需要你自备 puppet 方案）
# 常见：wechaty-puppet-wechat(兼容性不稳定/易失效)、wechaty-puppet-padlocal(商业)、wechaty-puppet-service(云服务)
WECHATY_PUPPET=
WECHATY_PUPPET_TOKEN=
WECHATY_NAME=wechaty-bot
# wechaty-puppet-wechat：放宽 puppet 层 Watchdog（秒），避免扫码/网页加载超过 60s 触发 WatchdogAgent reset
WECHATY_PUPPET_TIMEOUT_SECONDS=180
# 设为 0 可关闭 UOS 头（一般保持默认即可）
WECHATY_PUPPET_WECHAT_UOS=1
# 可选：自定义 UOS extspam 时填入；留空则用 puppet 内置
WECHATY_PUPPET_WECHAT_EXTSPAM=

# 本地开发建议（不连微信，只跑逻辑）：使用 wechaty-puppet-mock
WECHATY_PUPPET=wechaty-puppet-mock
WECHATY_PUPPET_TOKEN=
